CREATE SCHEMA IF NOT EXISTS awb;

CREATE TABLE IF NOT EXISTS awb.application_status_master (
  id              BIGSERIAL PRIMARY KEY,
  status_code     VARCHAR(40)  NOT NULL UNIQUE,
  status_name     VARCHAR(100) NOT NULL UNIQUE,
  display_order   INT          NOT NULL DEFAULT 0,
  active          BOOLEAN      NOT NULL DEFAULT TRUE,
  created_at      TIMESTAMP    NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS awb.payment_status_master (
  id              BIGSERIAL PRIMARY KEY,
  status_code     VARCHAR(20)  NOT NULL UNIQUE,
  status_name     VARCHAR(60)  NOT NULL UNIQUE,
  display_order   INT          NOT NULL DEFAULT 0,
  active          BOOLEAN      NOT NULL DEFAULT TRUE,
  created_at      TIMESTAMP    NOT NULL DEFAULT CURRENT_TIMESTAMP
);

